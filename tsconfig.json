{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "declaration": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "jsx": "react-jsx",
    "typeRoots": [
      "../skalfa-app-core/node_modules/@types"
    ],
    "paths": {
      "@skalfa/skalfa-app-core": ["../skalfa-app-core/dist/index.d.ts"],
      "socket.io-client": ["../skalfa-app-core/node_modules/socket.io-client"]
    }
  },
  "include": ["src/**/*"]
}
